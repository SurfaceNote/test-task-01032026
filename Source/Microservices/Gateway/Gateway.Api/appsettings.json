{
  "JwtSettings": {
    "Issuer": "ServiceIssuer",
    "Audience": "ServiceAudience",
    "SecretKey": "your-super-secret-key-very-long-and-random-12345",
    "ExpirationMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "user-service",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "AuthorizationPolicy": "Anonymous"
      }
    },
    "Clusters": {
      "user-service": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001/" }
        }
      },
      "finance-service": {
        "Destinations": {
          "d1": { "Address": "http://financeservice:8080/" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
